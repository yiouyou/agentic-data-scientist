# -----------------------------
# Core Required
# -----------------------------
# Required for Claude Code based coding agent.
ANTHROPIC_API_KEY="your-key-here"


# -----------------------------
# Required If Enabled In configs/llm_routing.yaml
# -----------------------------
# Only set the keys for profiles you actually enable in agent_routing.
# OPENAI_API_KEY="your-key-here"
# GOOGLE_API_KEY="your-key-here"
# DASHSCOPE_API_KEY="your-key-here"
# DEEPSEEK_API_KEY="your-key-here"


# -----------------------------
# Optional Runtime Overrides
# -----------------------------
# Optional model defaults (when not using role routing for a role).
# DEFAULT_MODEL="gemini-3.1-pro-preview"
# CODING_MODEL="claude-sonnet-4-6"
# REVIEW_MODEL="gemini-3.1-pro-preview"
# DEFAULT_CODING_EXECUTOR=claude_code
# DIRECT_CODING_EXECUTOR=claude_code

# Optional: custom routing config path.
# LLM_ROUTING_CONFIG_PATH="configs/llm_routing.yaml"
# Optional: workflow manifest search paths (OS path separator, default includes configs/workflows).
# WORKFLOW_MANIFEST_PATHS="configs/workflows"

# Optional: disable network tools.
# DISABLE_NETWORK_ACCESS=true

# Optional: role-level circuit breaker (temporary bypass of unstable primaries).
# LLM_CIRCUIT_BREAKER_ENABLED=true
# LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=2
# LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=120
# LLM_CIRCUIT_BREAKER_MAX_COOLDOWN_SECONDS=1800

# Optional: persistent compact run/stage/decision history for future learning-driven routing/planning.
# ADS_HISTORY_ENABLED=true
# ADS_HISTORY_DB_PATH=.agentic_ds_history.sqlite3
# ADS_LEARNING_ADVICE_ENABLED=true
# ADS_LEARNING_TOPK=3
# ADS_LEARNING_RECENT_RUNS=200
# ADS_PLAN_SELECTOR_ENABLED=false
# ADS_PLAN_SELECTOR_ROLLOUT_PERCENT=100
# ADS_PLAN_SELECTOR_INTENT_REGEXES=rna-?seq,variant,wgs
# ADS_PLAN_SELECTOR_ROLLOUT_SALT=
# ADS_PLAN_RANK_MIN_SWITCH_MARGIN=0.12
# ADS_PLAN_ONLY=false

# Optional: external coding CLI command templates (used by codex/opencode executors).
# If template contains {prompt}, prompt is injected into command string.
# Otherwise prompt is piped to stdin.
# CODEX_COMMAND_TEMPLATE="codex exec --model {model}"
# OPENCODE_COMMAND_TEMPLATE="opencode run --model {model}"


# -----------------------------
# Optional / Legacy Compatibility
# -----------------------------
# Used only for OpenRouter-based model invocations.
# OPENROUTER_API_KEY="your-key-here"
# OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
# OR_SITE_URL="k-dense.ai"
# OR_APP_NAME="Agentic Data Scientist"

# Optional: Context7 API Key for enhanced documentation access.
# CONTEXT7_API_KEY="your-key-here"
